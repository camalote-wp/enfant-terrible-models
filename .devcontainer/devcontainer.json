{
  "name": "camalote-wp/models",
  "image": "php:8.2-cli-alpine",
  "postCreateCommand": "sh .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "timonwong.shellcheck",
        "foxundermoon.shell-format",
        "kilocode.kilo-code"
      ]
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.local/share/kilo,target=/root/.local/share/kilo,type=bind"
  ]
}